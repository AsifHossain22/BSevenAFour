model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  role UserRole
  isBanned Boolean @default(false)
  reviews Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  technicianProfile TechnicianProfile?

  bookings Booking[] @relation("CustomerBookings")

  @@map("users")
}