model Service {
  id String @id @default(uuid())
  title String
  description String
  price Decimal
  categoryId String
  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  techProfileId String
  technician TechnicianProfile @relation(fields: [techProfileId], references: [id], onDelete: Cascade)
  bookings Booking[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services")
}